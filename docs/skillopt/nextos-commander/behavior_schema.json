{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["passed", "assessment", "scenario_reviews"],
  "properties": {
    "passed": { "type": "boolean" },
    "assessment": { "type": "string" },
    "scenario_reviews": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "assessment", "concerns"],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "clear-direct-execution",
              "optional-planning-angles",
              "optional-technical-design",
              "execution-review-rework",
              "no-program-container-controller",
              "background-control-lane",
              "project-lifecycle",
              "bottom-boundary-confirmation"
            ]
          },
          "assessment": { "type": "string" },
          "concerns": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
