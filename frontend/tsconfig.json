{
  "compilerOptions": {
    /* Base Options: */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitAny": false,
    "checkJs": false,
    /* Bundled projects */
    "lib": ["dom", "dom.iterable", "ES2022"],
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true,
    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.cjs",
    "**/*.js",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-e2e-real/types/**/*.ts",
    ".next-e2e-real/dev/types/**/*.ts",
    ".next-e2e-mock/types/**/*.ts",
    ".next-e2e-mock/dev/types/**/*.ts",
    ".next-e2e-record/types/**/*.ts",
    ".next-e2e-record/dev/types/**/*.ts",
    ".next-e2e-bottom-anchor-review-6133/types/**/*.ts",
    ".next-e2e-bottom-anchor-review-6133/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "generated"]
}
