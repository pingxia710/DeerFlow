          }
        ],
        "verdict": {
          "decision": "NEEDS_MORE",
          "reason": "Target is unresolved, but the next step is AI discovery rather than immediate human clarification.",
          "evidenceRefs": ["lane-discovery-1", "lane-opposition-1"]
        },
        "nextRoundContract": {
          "nextGoal": "Run read-only AI discovery to identify the project target and execution channel.",
          "inheritedBoundary": "read-only; no project modification; no credential or production access",
          "requiredEvidence": ["candidate project refs", "failed discovery probes", "execution channel refs or blocker"],
          "allowedDispatch": ["AI-authored discovery lane", "AI-authored opposition lane", "AI-authored monitor/evidence-checker lane"],
          "stopBefore": ["file writes", "production access", "credential access", "wrong-target mutation"],
          "userConfirmationNeeded": false
