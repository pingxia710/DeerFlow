{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["passed", "assessment", "scenario_reviews"],
  "properties": {
    "passed": { "type": "boolean" },
    "assessment": { "type": "string" },
    "scenario_reviews": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "assessment", "concerns"],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "review-observed-implementation",
              "small-fact-delegation",
              "bottom-boundary-confirmation"
            ]
          },
          "assessment": { "type": "string" },
          "concerns": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
