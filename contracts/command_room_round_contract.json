{
  "version": 1,
  "description": "Internal command-room audit fixture. It checks backend records without making the audit shape a chat UI contract.",
  "allowed_verdicts": ["PASS", "NEEDS_MORE", "BLOCKED", "STOP_CONFIRM"],
  "blocking_recommended_decisions": ["NEEDS_MORE", "BLOCKED", "STOP_CONFIRM"],
  "required_round_fields": [
    "roundId",
    "intentSeed",
    "goalHypothesis",
    "boundary",
    "capabilityRelease",
    "evidenceStandard",
    "dispatchPlan",
    "signals",
    "verdict",
    "nextRoundContract"
  ],
  "required_dispatch_lane_fields": [
    "laneId",
    "role",
    "task",
    "input",
    "allowedTools",
    "evidenceExpected",
    "redlineScope"
  ],
  "required_signal_fields": [
    "laneId",
    "role",
    "claim",
    "evidenceRefs",
    "unknownStale",
    "conflicts",
    "redlineTouched",
    "recommendedDecision",
    "nextAction"
  ],
  "required_next_round_fields": [
    "nextGoal",
    "inheritedBoundary",
    "requiredEvidence",
    "allowedDispatch",
    "stopBefore",
    "userConfirmationNeeded"
  ],
  "required_opposition_exemption_fields": [
    "notDispatchedBecause",
    "riskClass",
    "evidenceBasis",
    "noPermissionExpansion",
    "noPassFromWorkerSelfClaim"
  ],
  "prohibited_signal_fields": [
    "rawOutput",
    "stdout",
    "stderr",
    "terminalLog",
    "transcript",
    "hiddenReasoning"
  ],
  "cases": [
    {
      "name": "needs_more_with_opposition_blocks_weak_pass",
      "expected_valid": true,
      "round": {
        "roundId": "round-probe-needs-more",
        "intentSeed": "用户想把 worker 自述当成完成证据并进入真实执行。",
        "goalHypothesis": "只读判断现有证据是否足以 PASS。",
        "boundary": {
          "mode": "read-only",
          "nonGoals": ["do not modify files", "do not enter real execution"],
          "redlines": ["production", "credentials", "payments", "customer data"],
          "permission": "No permission to expand beyond the dry run."
        },
        "capabilityRelease": {
          "tools": ["task"],
          "subagents": ["opposition", "fact-finder"],
          "writeAllowed": false
        },
        "evidenceStandard": {
          "minimum": "PASS requires concrete EvidenceRefs or outputRefs; worker self-claims are insufficient.",
          "strongEvidenceTypes": ["file", "command", "test", "log", "screenshot", "outputRef"]
        },
        "dispatchPlan": [
          {
            "laneId": "lane-opposition-1",
            "role": "opposition",
            "task": "Attack Draft PASS, worker self-proof, summary-as-evidence, and permission smuggling.",
            "input": {
              "draftVerdict": "PASS",
              "draftNext": "enter real execution",
              "workerSignals": ["self-claims only"]
            },
            "allowedTools": [],
            "evidenceExpected": ["Evidence Signal with blocking RecommendedDecision if PASS is unsupported."],
            "redlineScope": ["permission expansion", "real execution"]
          },
          {
            "laneId": "lane-facts-1",
            "role": "fact-finder",
            "task": "Check whether supplied worker claims include concrete evidence.",
            "input": {
              "workerSignals": ["OAuth integrated: no refs", "tests green: no refs"]
            },
            "allowedTools": [],
            "evidenceExpected": ["Evidence Signal listing missing refs."],
            "redlineScope": []
          }
        ],
        "signals": [
          {
            "laneId": "lane-opposition-1",
            "role": "opposition",
            "claim": "Draft PASS is unsupported and real execution would smuggle permission.",
            "evidenceRefs": ["worker-a: no refs", "worker-b: no refs", "worker-c: summary only"],
            "evidenceState": "REDLINE",
            "selfAttestationOnly": true,
            "unknownStale": ["OAuth evidence missing", "test output missing", "opposition integration outputRef missing"],
            "conflicts": ["Draft Next conflicts with read-only boundary."],
            "redlineTouched": true,
            "recommendedDecision": "STOP_CONFIRM",
            "nextAction": "Collect concrete EvidenceRefs and obtain explicit authorization before real execution."
          },
          {
            "laneId": "lane-facts-1",
            "role": "fact-finder",
            "claim": "No decisive evidence exists in the supplied worker signals.",
            "evidenceRefs": ["provided worker claims only"],
            "evidenceState": "STALE",
            "selfAttestationOnly": true,
            "unknownStale": ["files missing", "commands missing", "logs missing", "tests missing"],
            "conflicts": ["Worker self-claims conflict with the evidence standard."],
            "redlineTouched": false,
            "recommendedDecision": "NEEDS_MORE",
            "nextAction": "Request concrete refs."
          }
        ],
        "verdict": {
          "decision": "STOP_CONFIRM",
          "reason": "Opposition found permission smuggling and missing decisive evidence.",
          "evidenceRefs": ["lane-opposition-1", "lane-facts-1"]
        },
        "nextRoundContract": {
          "nextGoal": "Collect concrete evidence for each integration claim.",
          "inheritedBoundary": "read-only; no real execution; no production writes",
          "requiredEvidence": ["OAuth file/config refs", "test command output", "subagent run record", "opposition outputRef"],
          "allowedDispatch": ["fact-finder", "project-librarian", "executor-checker"],
          "stopBefore": ["real execution", "production write", "new permission"],
          "userConfirmationNeeded": true
        }
      }
    },
